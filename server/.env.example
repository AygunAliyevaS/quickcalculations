### UVDesk forwarding configuration
# Set the full UVDesk ticket creation endpoint (including path).
# Example: https://help.example.com/api/tickets.json
UV_DESK_API_URL=
# API token or key used for Authorization. The server will send as Bearer token.
UV_DESK_API_TOKEN=

# Local server port
PORT=3001

# Optional provider mode; set to `uvdesk` to format the payload for UVDesk ticket creation.
# If empty, the server will forward a generic JSON payload.
UV_DESK_PROVIDER=uvdesk
